# Environment files — never commit real env files, but DO allow example/template files
.env
.env.local
.env.production
.env.*.local
.env.*
!.env.example
!**/.env.example

# Logs
/logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies / build output
node_modules/
vendor/
dist/
dist-ssr/
build/
*.local

# Mobile / native build tooling (defensive — not currently used by this project)
.gradle/
local.properties
*.jks
*.keystore
*.p12
*.mobileprovision

# Secrets, keys, and credentials of any kind
*.pem
*.key
!BackEnd/storage/*.key
*.pfx
*.cer
*.crt
serviceAccountKey*.json
firebase-adminsdk*.json
*-firebase-adminsdk-*.json
.cloudflare
cloudflare.toml
.wrangler/
*.credentials.json
credentials.json

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

.vite
base44/.app.jsonc

# Temporary files
*.tmp
*.temp
.cache/
