rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Shared helpers. Safe to call from any match block below — they only
    // reference fixed path segments / request.auth, never resource.data, so
    // they stay invariant across a query's whole result set (the lesson
    // from the events-list bug: a get()/exists() whose path depends on
    // resource.data breaks Firestore's ability to prove a list query safe;
    // one whose path depends only on request.auth.uid or an outer path
    // variable does not).
    function isFollowerOf(ownerUid) {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(ownerUid)/followers/$(request.auth.uid));
    }
    function isBlockedBy(ownerUid) {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(ownerUid)/blocks/$(request.auth.uid));
    }
    // visibility: 'everyone' | 'followers' | 'private', on the resource
    // itself. Owner always sees their own; the constant (per-query) parts
    // short-circuit before ever touching resource.data.
    function visibleTo(ownerUid) {
      return request.auth != null && request.auth.uid == ownerUid
        || resource.data.visibility == 'everyone'
        || (resource.data.visibility == 'followers' && isFollowerOf(ownerUid));
    }
    // Followers/following LIST visibility is itself privacy-gated by the
    // owner's own settings (a get() on the fixed ownerUid path, invariant
    // across the query — safe, same reasoning as above).
    function followersReadable(ownerUid) {
      return get(/databases/$(database)/documents/users/$(ownerUid)).data.privacy.followersVisibility == 'everyone'
        || (get(/databases/$(database)/documents/users/$(ownerUid)).data.privacy.followersVisibility == 'followers' && isFollowerOf(ownerUid));
    }
    function followingReadable(ownerUid) {
      return get(/databases/$(database)/documents/users/$(ownerUid)).data.privacy.followingVisibility == 'everyone'
        || (get(/databases/$(database)/documents/users/$(ownerUid)).data.privacy.followingVisibility == 'followers' && isFollowerOf(ownerUid));
    }

    // ---------------------------------------------------------------------
    // Collection-group read access. A nested block like
    // communities/{communityId}/members/{uid} only governs a get() or a
    // collection() query scoped to one already-known parent — it does NOT
    // extend to a collectionGroup() query (which spans every community's
    // members subcollection at once). Firestore requires a separate
    // top-level `{path=**}` rule for that query shape, full stop; without
    // one, the query 403s regardless of how permissive the nested rule is
    // (confirmed live: collectionGroup('members').where('uid','==',...)
    // rejected outright even though the nested rule is `allow read: if
    // true`). Each rule below mirrors its nested counterpart's existing
    // permission level exactly — this fixes reachability, it isn't a
    // security change. Add one here whenever a new collectionGroup() query
    // is introduced against a subcollection name used under multiple
    // parents.
    // ---------------------------------------------------------------------
    match /{path=**}/members/{uid} {
      allow read: if true; // matches communities/{id}/members/{uid}'s nested rule
    }
    match /{path=**}/attendees/{uid} {
      allow read: if request.auth != null; // matches events/{id}/attendees/{uid}'s nested rule
    }

    // ---------------------------------------------------------------------
    // Users
    // ---------------------------------------------------------------------
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      // A user can update their own doc but can't self-promote `role` or
      // flip `isVerified` — both are Worker-only (see Worker/src/routes/).
      // `photoVerified` IS self-settable — it only means "this photo was
      // captured live via the device camera", a UX signal, not a trust
      // claim like `isVerified` (which stays admin/Worker-only).
      allow update: if request.auth != null && request.auth.uid == uid
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isVerified']);
      allow delete: if false;

      match /fcmTokens/{tokenId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Saved places/events (bookmarks) — self-only.
      match /saved/{itemId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // "Add to plans" — a personal intent-to-attend list, distinct from a
      // plain bookmark. Same self-only shape as /saved.
      match /plans/{itemId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Mirror of communities/{id}/followers/{uid} — "groups I follow for
      // updates" without necessarily being a member. Self-only; not the
      // source of truth (that's the community's own followers subcollection,
      // which is what follower counts read from) — this is purely a
      // reverse-lookup index for the profile's "Following groups" tab.
      match /followedGroups/{communityId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Private block list — self-only, never publicly readable. Blocking
      // itself (with its cross-user cascade: revoke follow relationships,
      // pending requests, social-access grants) is a Worker operation — see
      // Worker/src/routes/relationships.ts — but the block record's owner
      // still writes it directly here as part of that flow authenticating
      // normally, since the Worker acts on the caller's stated intent, not
      // as a bypass for this specific doc.
      match /blocks/{blockedUid} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // ---------------------------------------------------------------
      // Follow relationships. `followers`/`following` docs are only ever
      // created as the direct result of an accepted followRequests doc
      // (checked via get() below) or by the trusted Worker (which bypasses
      // rules entirely) — never a bare self-write. Either side of the
      // relationship may delete their own copy (owner removing a follower,
      // or the follower unfollowing) — two independent, individually
      // authorized deletes rather than one atomic operation, which is an
      // acceptable small consistency risk (same tradeoff as elsewhere in
      // this file) since nothing security-sensitive depends on both
      // succeeding together.
      // ---------------------------------------------------------------
      match /followers/{followerUid} {
        allow read: if (request.auth != null && request.auth.uid == uid)
                    || followersReadable(uid);
        allow create: if request.auth != null && request.auth.uid == followerUid
                      && get(/databases/$(database)/documents/followRequests/$(followerUid + '_' + uid)).data.status == 'accepted';
        allow update: if false;
        allow delete: if request.auth != null && (request.auth.uid == uid || request.auth.uid == followerUid);
      }
      match /following/{targetUid} {
        allow read: if (request.auth != null && request.auth.uid == uid)
                    || followingReadable(uid);
        allow create: if request.auth != null && request.auth.uid == uid
                      && get(/databases/$(database)/documents/followRequests/$(uid + '_' + targetUid)).data.status == 'accepted';
        allow update: if false;
        allow delete: if request.auth != null && (request.auth.uid == uid || request.auth.uid == targetUid);
      }

      // A user's own visited-places log. Default visibility is enforced by
      // the client always writing 'private' unless the user explicitly
      // changes it (see savedApi-style pattern) — the rule itself only
      // gates *read*, not what visibility value may be chosen, since any
      // of the three values is a legitimate user choice.
      match /visitedPlaces/{placeId} {
        allow read: if visibleTo(uid);
        allow create, update: if request.auth != null && request.auth.uid == uid
                              && request.resource.data.source in ['user_confirmed', 'event_attendance'];
        allow delete: if request.auth != null && request.auth.uid == uid;
      }

      // Per-user community mute — self-owned, same shape as followedGroups.
      match /mutedCommunities/{communityId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Per-conversation "last read" marker, powering the Messages page's
      // unread-count badges — self-only, and irrelevant to anyone else's
      // security posture, so a plain self-write is enough.
      match /conversationReads/{conversationId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Recent-activity feed entries — self-authored at the moment of the
      // underlying action (e.g. right after joining a community), each
      // carrying its own visibility.
      match /activity/{activityId} {
        allow read: if visibleTo(uid);
        allow create: if request.auth != null && request.auth.uid == uid
                      && request.resource.data.visibility in ['everyone', 'followers', 'private'];
        allow update: if false;
        allow delete: if request.auth != null && request.auth.uid == uid;
      }

      // In-app notifications. Most are Worker-created (bypasses rules) as
      // part of an atomic operation (follow accepted, reveal approved) —
      // the three types below are the ones that originate purely
      // client-side (the *other* party creating their own request/doc), so
      // the client needs to be able to write the corresponding
      // notification for the recipient directly. Worst case a malicious
      // client spams harmless, deletable notification rows of these exact
      // types — no relationship state, grant, or privileged field is
      // reachable through this path.
      match /notifications/{notificationId} {
        allow read, delete: if request.auth != null && request.auth.uid == uid;
        // The owner can always update their own notifications (e.g.
        // mark-read/mark-all-read). One extra case: 'group_message' is a
        // single upserted-per-conversation doc (see
        // notificationsApi.notifyGroupMessage) that increments each time
        // someone new sends a message — the SENDER writes that update, not
        // the recipient, so this second branch lets them, but only ever
        // touching the count/read/createdAt fields of an already
        // group_message-typed doc, never anything else.
        allow update: if request.auth != null
                      && (request.auth.uid == uid
                          || (resource.data.type == 'group_message'
                              && request.resource.data.fromUid == request.auth.uid
                              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['count', 'read', 'createdAt', 'fromUid'])));
        allow create: if request.auth != null
                      && request.resource.data.fromUid == request.auth.uid
                      && request.resource.data.type in ['follow_request', 'social_reveal_request', 'social_access_revoked', 'group_message', 'event_join', 'event_update', 'community_invite'];
      }
    }

    // ---------------------------------------------------------------------
    // Usernames — a reservation collection purely for uniqueness: Firestore
    // `create` inherently fails if the doc already exists, which is all the
    // uniqueness guarantee this needs (no transaction/Worker required).
    // ---------------------------------------------------------------------
    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid
                    && username.matches('^[a-z0-9_]{3,20}$');
      allow update: if false;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // ---------------------------------------------------------------------
    // Follow requests. Only 'declined'/'cancelled'/re-'pending' transitions
    // are plain client updates — setting 'accepted' goes through the Worker
    // (Worker/src/routes/relationships.ts) since it must atomically also
    // create both follower/following docs and a notification; allowing a
    // bare client update straight to 'accepted' here would let the owner
    // "accept" without ever actually creating the relationship records.
    // ---------------------------------------------------------------------
    match /followRequests/{requestId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid);
      allow create: if request.auth != null
                    && request.resource.data.fromUid == request.auth.uid
                    && request.resource.data.toUid != request.auth.uid
                    && request.resource.data.status == 'pending'
                    && requestId == request.auth.uid + '_' + request.resource.data.toUid
                    && !isBlockedBy(request.resource.data.toUid);
      allow update: if request.auth != null
                    && ((request.auth.uid == resource.data.toUid
                         && request.resource.data.status == 'declined' && resource.data.status == 'pending')
                        || (request.auth.uid == resource.data.fromUid
                            && request.resource.data.status in ['cancelled', 'pending'] && resource.data.status != 'accepted'));
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // Social links — kept out of the publicly-readable users/{uid} doc
    // entirely (Firestore has no field-level read security within one
    // document). Each platform is its OWN document specifically so a grant
    // can name individual platforms and have that be genuinely enforced by
    // rules, not just hidden in the UI.
    // ---------------------------------------------------------------------
    function isValidPlatformUrl(platform, url) {
      return url is string && url.size() < 500
        && (
          (platform == 'instagram' && url.matches('^https://(www[.])?instagram[.]com/.*$'))
          || (platform == 'facebook' && url.matches('^https://(www[.])?facebook[.]com/.*$'))
          || (platform == 'strava' && url.matches('^https://(www[.])?strava[.]com/.*$'))
          || (platform == 'website' && url.matches('^https://.+$'))
        );
    }
    match /userSocialLinks/{uid} {
      match /platforms/{platform} {
        allow read: if request.auth != null
                    && (request.auth.uid == uid
                        || (exists(/databases/$(database)/documents/socialAccess/$(uid)/grants/$(request.auth.uid))
                            && platform in get(/databases/$(database)/documents/socialAccess/$(uid)/grants/$(request.auth.uid)).data.platforms));
        allow write: if request.auth != null && request.auth.uid == uid
                     && isValidPlatformUrl(platform, request.resource.data.url);
        allow delete: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ---------------------------------------------------------------------
    // Social-link reveal requests — same 'accepted' constraint as follow
    // requests: only the Worker can approve, since approval must also
    // create the socialAccess grant + a notification atomically.
    // ---------------------------------------------------------------------
    match /socialRevealRequests/{requestId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.requesterUid || request.auth.uid == resource.data.ownerUid);
      allow create: if request.auth != null
                    && request.resource.data.requesterUid == request.auth.uid
                    && request.resource.data.ownerUid != request.auth.uid
                    && request.resource.data.status == 'pending'
                    && requestId == request.auth.uid + '_' + request.resource.data.ownerUid
                    && !isBlockedBy(request.resource.data.ownerUid);
      allow update: if request.auth != null && request.auth.uid == resource.data.ownerUid
                    && request.resource.data.status == 'declined' && resource.data.status == 'pending';
      allow delete: if false;
    }

    // Grants are Worker-only to create (part of the atomic reveal-accept),
    // but the owner can revoke one directly at any time — a single-document
    // delete needs no cross-document consistency.
    match /socialAccess/{ownerUid} {
      match /grants/{viewerUid} {
        allow read: if request.auth != null && (request.auth.uid == ownerUid || request.auth.uid == viewerUid);
        allow create, update: if false;
        allow delete: if request.auth != null && request.auth.uid == ownerUid;
      }
    }

    // ---------------------------------------------------------------------
    // Communities / clubs / groups
    // ---------------------------------------------------------------------
    match /communities/{communityId} {
      // A member's role is 'owner' | 'moderator' | 'member'. 'organiser' is
      // a legacy synonym for 'moderator' from before the role model was
      // named explicitly — communities created before that rename still
      // have their creator's doc stored as 'organiser', and this is
      // accepted everywhere a moderator-tier check happens rather than
      // requiring a data migration. New self-seeds always write 'owner'
      // (see communitiesApi.create()); nothing new ever writes 'organiser'.
      function isModeratorRole(role) {
        return role == 'moderator' || role == 'organiser';
      }

      // Public browsing — signed out visitors can view the directory.
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;
      // The owner can change anything (except reassigning ownerId itself).
      // A moderator may ONLY ever touch pinnedMessageId through this path —
      // editing core details (name/description/category/imageURL/
      // joinPolicy/rules/cta*) is owner-only, per the admin-controls spec.
      allow update: if request.auth != null
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['ownerId'])
                    && (resource.data.ownerId == request.auth.uid
                        || (exists(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid))
                            && isModeratorRole(get(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid)).data.role)
                            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pinnedMessageId', 'updatedAt'])));
      allow delete: if request.auth != null && resource.data.ownerId == request.auth.uid;

      match /members/{uid} {
        allow read: if true;
        // Self-join only, and always as a plain member — the moderator
        // tier can only be granted by the owner (below, via update), never
        // self-assigned. The one exception is the community's own
        // creator, who seeds their own 'owner' membership doc at
        // community-creation time (there's no other member yet who could
        // grant it to them, and ownerId on the parent doc already names
        // them anyway — this just keeps the member doc consistent with it).
        //
        // Invite-only communities: unlike the events invite-link case (a
        // *read* problem a rule can never fully solve — see the note on
        // events/{eventId} — this is a *write*, so request.resource.data is
        // directly comparable. The joiner submits `joinToken` as part of
        // their own membership doc, checked directly against the
        // community's stored inviteToken; a wrong/missing token simply
        // fails the write, no Worker round-trip needed.
        allow create: if request.auth != null && request.auth.uid == uid
                      && (request.resource.data.role == 'member'
                          || (request.resource.data.role == 'owner'
                              && get(/databases/$(database)/documents/communities/$(communityId)).data.ownerId == uid))
                      && (get(/databases/$(database)/documents/communities/$(communityId)).data.joinPolicy != 'invite_only'
                          || get(/databases/$(database)/documents/communities/$(communityId)).data.ownerId == uid
                          || request.resource.data.joinToken == get(/databases/$(database)/documents/communities/$(communityId)).data.inviteToken);
        // Two ways a member doc gets deleted: (1) self-leave, blocked for
        // the owner (must delete the community instead — never leave it
        // ownerless); (2) an admin removing someone else, which can never
        // target the owner's own row (only the owner can ever remove that
        // one, via self-leave, which is itself blocked — i.e. the owner's
        // row is simply undeletable through this path, by design) — and a
        // moderator may only ever remove a plain 'member', never another
        // moderator (that stays owner-only, same as promote/demote below).
        allow delete: if request.auth != null
                      && get(/databases/$(database)/documents/communities/$(communityId)).data.ownerId != uid
                      && (request.auth.uid == uid
                          || get(/databases/$(database)/documents/communities/$(communityId)).data.ownerId == request.auth.uid
                          || (isModeratorRole(get(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid)).data.role)
                              && resource.data.role == 'member'));
        // Promote/demote is owner-only — a moderator can add/remove plain
        // members (above) but never manage other moderators. Value is
        // constrained so this path can't be used to write anything else.
        allow update: if request.auth != null && request.auth.uid != uid
                      && get(/databases/$(database)/documents/communities/$(communityId)).data.ownerId == request.auth.uid
                      && request.resource.data.role in ['moderator', 'member'];
      }

      // "Following" a community/group is a lightweight public subscription
      // for updates — distinct from `members` (active participation). No
      // approval needed (unlike following a *person*, see followRequests
      // above): communities are public entities, not private individuals,
      // so a plain self-authorized create/delete is enough. Mirrored at
      // users/{uid}/followedGroups/{communityId} below for the "groups I
      // follow" list — two independent writes, not atomic (same acceptable
      // small-inconsistency tradeoff used elsewhere in this file).
      match /followers/{uid} {
        allow read: if true;
        allow create, update: if request.auth != null && request.auth.uid == uid;
        allow delete: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ---------------------------------------------------------------------
    // Events
    //
    // `visibility` has three values: 'public' (anyone), 'members' (a
    // community's own members — the spec's "My community only"), and
    // 'invite_link' (resolves only via its exact, unguessable inviteToken —
    // see the note below on why that can't be enforced by a rule alone).
    // ---------------------------------------------------------------------
    match /events/{eventId} {
      function isEventAttendee() {
        return request.auth != null
          && exists(/databases/$(database)/documents/events/$(eventId)/attendees/$(request.auth.uid));
      }
      // For a group-linked event, the community's owner/organiser can
      // edit or cancel it too, not just the original host — per the admin
      // -controls spec ("Moderator: ...edit events tied to the group").
      // `cid != null` must short-circuit first: get() on a null path
      // throws, it doesn't just evaluate falsy.
      function isCommunityAdminFor(cid) {
        return cid != null && request.auth != null
          && (get(/databases/$(database)/documents/communities/$(cid)).data.ownerId == request.auth.uid
              || get(/databases/$(database)/documents/communities/$(cid)/members/$(request.auth.uid)).data.role in ['moderator', 'organiser']);
      }
      // A plain rule has no way to check "did the caller's query include a
      // `where('inviteToken','==', theRealToken)` filter" — reads only ever
      // see resource.data and request.auth, never the request's own filter
      // values. So an unfiltered `list` against this collection could not
      // be proven safe if invite_link docs were broadly readable, and
      // Firestore would reject it entirely (same "unprovable query" 403
      // behaviour already documented in eventsApi.js) UNLESS the requester
      // is already the host or an attendee — which IS provable per-document
      // for a scoped `get()`/query on a single known id. The actual token
      // check happens one layer up: eventsApi.getByInviteToken() queries
      // `where('inviteToken','==', token)`, and Firestore's query engine
      // simply returns zero rows for a guessed/wrong token — nobody can
      // enumerate "all invite_link events" without already holding each
      // one's real token, which never appears in any generic list/browse
      // query this app ever issues.
      allow read: if resource.data.visibility == 'public'
                  || (resource.data.visibility == 'members'
                      && request.auth != null
                      && exists(/databases/$(database)/documents/communities/$(resource.data.communityId)/members/$(request.auth.uid)))
                  || (request.auth != null && resource.data.organiserId == request.auth.uid)
                  || isEventAttendee();
      allow create: if request.auth != null
                    && request.resource.data.organiserId == request.auth.uid
                    && request.resource.data.visibility in ['public', 'members', 'invite_link']
                    && (request.resource.data.communityId == null
                        || exists(/databases/$(database)/documents/communities/$(request.resource.data.communityId)/members/$(request.auth.uid)));
      // The host, or (for a group-linked event) the community's owner/
      // organiser, may edit or cancel; organiserId itself is fixed.
      // Cancelling sets status='cancelled' rather than deleting — the
      // paired chat is archived (a client-side flag flip), never deleted.
      allow update: if request.auth != null
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['organiserId'])
                    && (resource.data.organiserId == request.auth.uid || isCommunityAdminFor(resource.data.communityId));
      allow delete: if request.auth != null
                    && (resource.data.organiserId == request.auth.uid || isCommunityAdminFor(resource.data.communityId));

      // status: 'going' | 'interested' | 'waitlisted'. Capacity/waitlist
      // placement is decided client-side (count then write, same accepted
      // small race window as elsewhere in this file) — the rule only
      // enforces *who* may write *their own* attendance record, not which
      // status value they land in.
      match /attendees/{uid} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null && request.auth.uid == uid;
        allow delete: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ---------------------------------------------------------------------
    // Conversations — group/community messaging only, never 1:1 DMs.
    //
    // Three membership shapes are supported on the same collection:
    //  - Legacy/generic: an explicit `memberIds` array on the conversation
    //    doc (how the pre-communities test conversations were seeded via
    //    the Worker/admin bootstrap — kept working, not migrated).
    //  - Community-scoped: conversationId == communityId, created once
    //    alongside the community itself, with membership derived from the
    //    community's own /members subcollection instead of a duplicated
    //    array — nothing to keep in sync on join/leave.
    //  - Event-scoped: conversationId == eventId, same reasoning — the
    //    event's own /attendees subcollection is the membership source of
    //    truth, so joining/leaving the event is all that's needed and there
    //    is nothing else to keep in sync here either.
    // ---------------------------------------------------------------------
    match /conversations/{conversationId} {
      function isLegacyMember() {
        return request.auth != null
          && 'memberIds' in resource.data
          && request.auth.uid in resource.data.memberIds;
      }
      function isCommunityMember() {
        return request.auth != null
          && exists(/databases/$(database)/documents/communities/$(conversationId)/members/$(request.auth.uid));
      }
      function isEventAttendeeOf() {
        return request.auth != null
          && exists(/databases/$(database)/documents/events/$(conversationId)/attendees/$(request.auth.uid));
      }

      allow read: if isLegacyMember() || isCommunityMember() || isEventAttendeeOf();
      // Only the community's owner creates the paired conversation doc, at
      // community-creation time; only an event's organiser creates its
      // paired conversation, at event-creation time — both in the same
      // client batch write as their parent doc. Legacy memberIds-based
      // conversations are Worker/admin-created only (the Worker's
      // service-account credentials bypass these rules entirely).
      allow create: if request.auth != null
                    && ((request.resource.data.type == 'community'
                         && request.resource.data.communityId == conversationId
                         && get(/databases/$(database)/documents/communities/$(conversationId)).data.ownerId == request.auth.uid)
                        || (request.resource.data.type == 'event'
                            && request.resource.data.eventId == conversationId
                            && get(/databases/$(database)/documents/events/$(conversationId)).data.organiserId == request.auth.uid));
      // The host archives the chat (isArchived=true) when cancelling the
      // event — the only conversation-level field this app ever updates
      // post-creation.
      allow update: if request.auth != null
                    && 'eventId' in resource.data
                    && get(/databases/$(database)/documents/events/$(conversationId)).data.organiserId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isArchived']);
      allow delete: if false;

      match /messages/{messageId} {
        // `resource` inside /messages/{messageId} refers to the message
        // doc, not the conversation, so the conversation must be re-fetched
        // explicitly here rather than reusing the outer isLegacyMember()/
        // isCommunityMember() helpers (which rely on the outer `resource`).
        function conversation() {
          return get(/databases/$(database)/documents/conversations/$(conversationId)).data;
        }
        function isMemberOfConversation() {
          return request.auth != null
            && (('memberIds' in conversation() && request.auth.uid in conversation().memberIds)
                || exists(/databases/$(database)/documents/communities/$(conversationId)/members/$(request.auth.uid))
                || exists(/databases/$(database)/documents/events/$(conversationId)/attendees/$(request.auth.uid)));
        }
        // Announcements are the one message type gated by role — only the
        // community's owner/organiser (moderator) may post one, per the
        // admin-controls spec. Only meaningful for community conversations;
        // event chats have no announcement concept.
        function canPostAnnouncement() {
          return conversation().type == 'community'
            && (get(/databases/$(database)/documents/communities/$(conversation().communityId)).data.ownerId == request.auth.uid
                || get(/databases/$(database)/documents/communities/$(conversation().communityId)/members/$(request.auth.uid)).data.role in ['moderator', 'organiser']);
        }

        allow read: if isMemberOfConversation();
        allow create: if isMemberOfConversation()
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.isDeleted == false
          && (request.resource.data.type != 'announcement' || canPostAnnouncement());
        // Two distinct update shapes: (1) a sender soft-deleting their own
        // message (isDeleted=true, content cleared) — never hard-delete,
        // a moderator deleting someone else's message goes through the
        // Worker instead, which authenticates as the service account and
        // bypasses these rules; (2) any member toggling a reaction. The
        // reaction branch doesn't attempt to prove "only your own uid
        // moved within the map" — Firestore rules can't cleanly express
        // that per-key-array diff, and the actual stakes are low (reaction
        // pills only ever show an emoji + count, never who reacted, per
        // the product spec, so a spoofed uid in someone else's reaction
        // array is a cosmetic count nudge, not a real leak).
        allow update: if request.auth != null
          && ((resource.data.senderId == request.auth.uid
               && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isDeleted', 'body', 'imageURL'])
               && request.resource.data.isDeleted == true)
              || (isMemberOfConversation()
                  && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])));
        allow delete: if false;
      }
    }

    // ---------------------------------------------------------------------
    // Reports — write-only from the client; only staff (custom claim set by
    // the Worker's admin routes) can read the queue. Never client-readable
    // by the general public, and never editable by the reporter afterwards.
    // ---------------------------------------------------------------------
    match /reports/{reportId} {
      allow create: if request.auth != null && request.resource.data.reporterId == request.auth.uid;
      allow read: if request.auth != null && request.auth.token.role in ['admin', 'moderator'];
      allow update, delete: if false;
    }
  }
}
